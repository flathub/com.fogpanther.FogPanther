{
    "app-id": "com.fogpanther.FogPanther",
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "command": "fogpanther",
    "finish-args": [
        "--share=ipc",
        "--share=network",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--socket=cups",
        "--device=dri",
        "--filesystem=xdg-pictures:rw",
        "--filesystem=xdg-documents:rw",
        "--filesystem=xdg-download:rw",
        "--filesystem=xdg-desktop:rw",
        "--filesystem=/run/media",
        "--filesystem=/media",
        "--env=GDK_PIXBUF_MODULE_FILE=/app/lib/gdk-pixbuf-2.0/2.10.0/loaders.cache"
    ],
    "modules": [
        {
            "name": "fogpanther",
            "buildsystem": "simple",
            "build-commands": [
                "install -Dm755 bin/fogpanther bin/fogpanther-thumbnailer -t /app/bin/",
                "cp -a lib/. /app/lib/",
                "cp -a share/. /app/share/",
                "gdk-pixbuf-query-loaders /app/lib/gdk-pixbuf-2.0/2.10.0/loaders/*.so /usr/lib/*/gdk-pixbuf-2.0/2.10.0/loaders/*.so > /app/lib/gdk-pixbuf-2.0/2.10.0/loaders.cache",
                "sed -i 's|;photoshop;gimp;|;|' /app/share/applications/com.fogpanther.FogPanther.desktop"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://www.fogpanther.com/releases/fogpanther-0.7.4-1-x86_64.tar.xz",
                    "sha256": "267ed8a516c633021d2296ef32d61d351b1b733b675433e826a384ad2cb9c7bc",
                    "only-arches": ["x86_64"]
                },
                {
                    "type": "archive",
                    "url": "https://www.fogpanther.com/releases/fogpanther-0.7.4-1-aarch64.tar.xz",
                    "sha256": "f0bcfa888ea95f277df9feecbc8f45ac74ca6193ad8920802703fc9c75b144fe",
                    "only-arches": ["aarch64"]
                }
            ]
        }
    ]
}
