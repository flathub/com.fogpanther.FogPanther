{
    "app-id": "com.fogpanther.FogPanther",
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "command": "fogpanther",
    "finish-args": [
        "--share=ipc",
        "--share=network",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--socket=cups",
        "--device=dri",
        "--filesystem=xdg-pictures:rw",
        "--filesystem=xdg-documents:rw",
        "--filesystem=xdg-download:rw",
        "--filesystem=xdg-desktop:rw",
        "--filesystem=/run/media",
        "--filesystem=/media",
        "--env=GDK_PIXBUF_MODULE_FILE=/app/lib/gdk-pixbuf-2.0/2.10.0/loaders.cache"
    ],
    "modules": [
        {
            "name": "fogpanther",
            "buildsystem": "simple",
            "build-commands": [
                "install -Dm755 bin/fogpanther bin/fogpanther-thumbnailer -t /app/bin/",
                "cp -a lib/. /app/lib/",
                "cp -a share/. /app/share/",
                "gdk-pixbuf-query-loaders /app/lib/gdk-pixbuf-2.0/2.10.0/loaders/*.so /usr/lib/*/gdk-pixbuf-2.0/2.10.0/loaders/*.so > /app/lib/gdk-pixbuf-2.0/2.10.0/loaders.cache",
                "sed -i 's|;photoshop;gimp;|;|' /app/share/applications/com.fogpanther.FogPanther.desktop"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://www.fogpanther.com/releases/fogpanther-0.7.3-1-x86_64.tar.xz",
                    "sha256": "fbb8d5bff0ac79f3b8e2c146e6bbc3b645c15916485e028b43dc649bc5e53b3a",
                    "only-arches": ["x86_64"]
                },
                {
                    "type": "archive",
                    "url": "https://www.fogpanther.com/releases/fogpanther-0.7.3-1-aarch64.tar.xz",
                    "sha256": "76869a5e72b23dd65aad8aca217e2461a813ef5c4ca189e2762e5ece231c8d10",
                    "only-arches": ["aarch64"]
                }
            ]
        }
    ]
}
