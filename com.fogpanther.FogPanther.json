{
    "app-id": "com.fogpanther.FogPanther",
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "command": "fogpanther",
    "finish-args": [
        "--share=ipc",
        "--share=network",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--socket=cups",
        "--device=dri",
        "--filesystem=host:rw",
        "--filesystem=/run/media",
        "--filesystem=/media",
        "--env=GDK_PIXBUF_MODULE_FILE=/app/lib/gdk-pixbuf-2.0/2.10.0/loaders.cache"
    ],
    "modules": [
        {
            "name": "fogpanther",
            "buildsystem": "simple",
            "build-commands": [
                "install -Dm755 bin/fogpanther bin/fogpanther-thumbnailer -t /app/bin/",
                "cp -a lib/. /app/lib/",
                "cp -a share/. /app/share/",
                "gdk-pixbuf-query-loaders /app/lib/gdk-pixbuf-2.0/2.10.0/loaders/*.so /usr/lib/*/gdk-pixbuf-2.0/2.10.0/loaders/*.so > /app/lib/gdk-pixbuf-2.0/2.10.0/loaders.cache",
                "sed -i 's|;photoshop;gimp;|;|' /app/share/applications/com.fogpanther.FogPanther.desktop"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://www.fogpanther.com/releases/fogpanther-0.7.2-2-x86_64.tar.xz",
                    "sha256": "157c3f0c9daa450f692d12241edab837db5e743c678d8435e6d663b807a1340e",
                    "only-arches": ["x86_64"]
                },
                {
                    "type": "archive",
                    "url": "https://www.fogpanther.com/releases/fogpanther-0.7.2-2-aarch64.tar.xz",
                    "sha256": "9c3063fdf2737ef52f334b0e9fa07cc897ef761b59b5c0237b2f3e1c54d6a450",
                    "only-arches": ["aarch64"]
                }
            ]
        }
    ]
}
