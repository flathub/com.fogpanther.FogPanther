{
    "app-id": "com.fogpanther.FogPanther",
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "command": "fogpanther",
    "finish-args": [
        "--share=ipc",
        "--share=network",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--socket=cups",
        "--device=dri",
        "--filesystem=home",
        "--filesystem=/run/media",
        "--filesystem=/media",
        "--env=GDK_PIXBUF_MODULE_FILE=/app/lib/gdk-pixbuf-2.0/2.10.0/loaders.cache"
    ],
    "modules": [
        {
            "name": "fogpanther",
            "buildsystem": "simple",
            "build-commands": [
                "install -Dm755 bin/fogpanther bin/fogpanther-thumbnailer -t /app/bin/",
                "cp -a lib/. /app/lib/",
                "cp -a share/. /app/share/",
                "gdk-pixbuf-query-loaders /app/lib/gdk-pixbuf-2.0/2.10.0/loaders/*.so /usr/lib/*/gdk-pixbuf-2.0/2.10.0/loaders/*.so > /app/lib/gdk-pixbuf-2.0/2.10.0/loaders.cache",
                "sed -i 's|;photoshop;gimp;|;|' /app/share/applications/com.fogpanther.FogPanther.desktop"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://www.fogpanther.com/releases/fogpanther-0.7.4-2-x86_64.tar.xz",
                    "sha256": "f42309e1f9febb2cdf3f47377b66621364c7d005137657704e5b7ce18db5c1de",
                    "only-arches": ["x86_64"]
                },
                {
                    "type": "archive",
                    "url": "https://www.fogpanther.com/releases/fogpanther-0.7.4-2-aarch64.tar.xz",
                    "sha256": "55185a9eaac9538a54e61201b9fc6e6d3c54e2647775f2ab30d64d5fcab69b7d",
                    "only-arches": ["aarch64"]
                }
            ]
        }
    ]
}
