{
    "app-id": "com.fogpanther.FogPanther",
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "command": "fogpanther",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri"
    ],
    "modules": [
        {
            "name": "fogpanther",
            "buildsystem": "simple",
            "build-commands": [
                "install -Dm755 bin/fogpanther bin/fogpanther-thumbnailer -t /app/bin/",
                "install -Dm644 LICENSE -t /app/share/licenses/com.fogpanther.FogPanther/",
                "cp -a lib/. /app/lib/",
                "cp -a share/. /app/share/",
                "sed -i 's|https://github.com/fogpanther/fogpanther/issues|https://fogpanther.com/support|' /app/share/metainfo/com.fogpanther.FogPanther.metainfo.xml"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://www.fogpanther.com/releases/fogpanther-0.7.1-1-x86_64.tar.xz",
                    "sha256": "57c31928dc2ada3d5216af89c952549d380b1ed0d05dfd381072e8523b925258",
                    "only-arches": ["x86_64"]
                },
                {
                    "type": "archive",
                    "url": "https://www.fogpanther.com/releases/fogpanther-0.7.1-1-aarch64.tar.xz",
                    "sha256": "08fed89509d50ba21cf8638f3173d5f170c72e2d1c0ae73bdbd3a79f2d4d5bef",
                    "only-arches": ["aarch64"]
                }
            ]
        }
    ]
}
