{
    "app-id": "com.fogpanther.FogPanther",
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "command": "fogpanther",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri"
    ],
    "modules": [
        {
            "name": "fogpanther",
            "buildsystem": "simple",
            "build-commands": [
                "install -Dm755 bin/fogpanther bin/fogpanther-thumbnailer -t /app/bin/",
                "install -Dm644 LICENSE -t /app/share/licenses/com.fogpanther.FogPanther/",
                "cp -a lib/. /app/lib/",
                "cp -a share/. /app/share/",
                "sed -i 's|https://github.com/fogpanther/fogpanther/issues|https://fogpanther.com/support|' /app/share/metainfo/com.fogpanther.FogPanther.metainfo.xml"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://www.fogpanther.com/releases/fogpanther-0.7.0-1-x86_64.tar.xz",
                    "sha256": "042058ca3426da699b379df9ae5eaba61038daf9538b5fa683acf9c8757dd078",
                    "only-arches": ["x86_64"]
                },
                {
                    "type": "archive",
                    "url": "https://www.fogpanther.com/releases/fogpanther-0.7.0-1-aarch64.tar.xz",
                    "sha256": "81c0ac6a6d9c9c3fc2eb57b92cda74003c11f3adff986c4a8bf67ff51e4b847c",
                    "only-arches": ["aarch64"]
                }
            ]
        }
    ]
}
